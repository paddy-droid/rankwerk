# Rankwerk — required environment variables
# Local dev: copy to `.env.local` and fill in real values (never commit .env.local).
# Netlify: set these under Site settings → Environment variables (NOT in the repo).

# Google Gemini API key (Google AI Studio) — used for the audit analysis.
GEMINI_API_KEY=your-gemini-key-here

# Jina AI key (https://jina.ai) — used by the Jina Reader to fetch clean shop content.
JINA_API_KEY=your-jina-key-here

# --- Google Search Console (GSC) OAuth ---------------------------------------
# Optional feature: connect a Search Console property to prove ranking impact.
# Create an OAuth client (type: Web application) in the Google Cloud Console,
# enable the "Search Console API", and register the redirect URI
#   https://rankwerk.netlify.app/api/gsc/callback  (+ your preview/local URLs).
# Scope used: https://www.googleapis.com/auth/webmasters.readonly (read-only).
GSC_CLIENT_ID=your-google-oauth-client-id
GSC_CLIENT_SECRET=your-google-oauth-client-secret
# Optional: force an exact redirect URI. If unset, it is derived from the
# request origin (recommended). Must match a URI registered in Google Cloud.
GSC_REDIRECT_URI=
